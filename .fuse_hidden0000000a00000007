<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
  // Live clock for the hero meta block
  (function () {
    const el = document.getElementById('local-time');
    if (!el) return;
    function update() {
      const now = new Date();
      // Show Phoenix time (MST, UTC-7, no DST)
      const opts = { hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'America/Phoenix' };
      const t = new Intl.DateTimeFormat('en-US', opts).format(now);
      el.textContent = t.replace(':', ' ') + ' MST';
    }
    update();
    setInterval(update, 30000);
  })();

  // Project Journey: broadsheet - horizontal rail fills on scroll, columns reveal,
  // nodes ink in as the rail passes them.
  (function () {
    const broadsheet = document.getElementById('broadsheet');
    if (!broadsheet) return;
    const cols = broadsheet.querySelectorAll('.bs-col');

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      cols.forEach(c => c.classList.add('visible'));
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { rootMargin: '0px 0px -25% 0px', threshold: 0.1 });

    cols.forEach(col => observer.observe(col));
  })();

  // Operating principles: reveal header + stagger the cards on first scroll-in
  (function () {
    const section = document.querySelector('.principles');
    if (!section) return;
    const cards = section.querySelectorAll('.principle');

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      section.classList.add('revealed');
      cards.forEach(c => c.classList.add('revealed'));
      return;
    }

    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          section.classList.add('revealed');
          cards.forEach(c => c.classList.add('revealed'));
          obs.disconnect();
        }
      });
    }, { rootMargin: '0px 0px -20% 0px', threshold: 0.15 });

    observer.observe(section);
  })();
</script>

